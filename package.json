{
  "name": "backend-express-template",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "test": "node --test \"test/*.test.js\"",
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "db:migrate": "npx sequelize-cli db:migrate",
    "db:migrate:undo": "npx sequelize-cli db:migrate:undo",
    "db:migrate:undo:all": "npx sequelize-cli db:migrate:undo:all",
    "db:seed": "npx sequelize-cli db:seed:all",
    "db:seed:undo": "npx sequelize-cli db:seed:undo:all",
    "db:setup": "npm run db:migrate && npm run db:seed",
    "db:reset": "npm run db:migrate:undo:all && npm run db:setup"
  },
  "author": "",
  "license": "ISC",
  "description": "Express.js backend template with authentication, user management, and role-based access control",
  "dependencies": {
    "axios": "^1.7.9",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "moment-timezone": "^0.5.47",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^8.0.4",
    "pg": "^8.20.0",
    "pg-hstore": "^2.3.4",
    "resend": "^6.10.0",
    "sequelize": "^6.37.5",
    "sequelize-cli": "^6.6.2",
    "uuid": "^12.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.9"
  }
}
